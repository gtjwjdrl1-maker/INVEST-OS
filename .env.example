# ── Google Gemini API ─────────────────────────────────────
# 발급: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── DART 공시 API ─────────────────────────────────────────
# 발급: https://opendart.fss.or.kr
DART_API_KEY=your_dart_api_key_here

# ── FRED 거시경제 데이터 ──────────────────────────────────
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── 네이버 뉴스 검색 API ─────────────────────────────────
# 발급: https://developers.naver.com
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ── KIS 한국투자증권 (읽기 전용 · 잔고 조회만) ───────────
# 발급: https://apiportal.koreainvestment.com
# 비워두면 더미 데이터로 동작
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here
KIS_MODE=real

# ── 카카오 나에게 보내기 ──────────────────────────────────
# 발급: https://developers.kakao.com
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here

# ── Gmail SMTP ────────────────────────────────────────────
GMAIL_USER=your_gmail_here
GMAIL_APP_PASSWORD=your_app_password_here
